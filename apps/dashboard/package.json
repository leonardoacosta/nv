{
  "name": "nova-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "node server.js",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t nova-cc-session:latest ./docker/cc-session",
    "docker:push": "docker tag nova-cc-session:latest ${REGISTRY:-ghcr.io/nyaptor}/nova-cc-session:latest && docker push ${REGISTRY:-ghcr.io/nyaptor}/nova-cc-session:latest"
  },
  "dependencies": {
    "geist": "^1.3.1",
    "http-proxy": "^1.18.1",
    "lucide-react": "^0.469.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.15",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
