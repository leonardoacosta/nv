# Nova environment variables
# Copy to config/env and fill in values: cp config/env.example config/env

# Telegram (required)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Jira (optional — enables Jira tools)
#   JIRA_API_TOKEN_PERSONAL / JIRA_USERNAME_PERSONAL
#   JIRA_API_TOKEN_LLC / JIRA_USERNAME_LLC
#   Unqualified JIRA_API_TOKEN / JIRA_USERNAME serve as fallback.
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# Discord relay (optional — enables Discord relay service)
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNELS=123456789,987654321

# Teams / MS Graph (optional — enables Teams relay + email)
#   Tenant ID can also be set in [teams].tenant_id in config TOML.
MS_GRAPH_CLIENT_ID=your-azure-ad-client-id
MS_GRAPH_CLIENT_SECRET=your-azure-ad-client-secret
MS_GRAPH_TENANT_ID=your-azure-ad-tenant-id
