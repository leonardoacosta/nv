  "decisions": [
    {
      "date": "2026-03-26",
      "decision": "SSH to CloudPC is primary for all MS Graph operations",
      "rationale": "Direct Graph API CLIs are unproven with real creds. SSH is the proven Rust pattern.",
      "source": "user"
    },
    {
      "date": "2026-03-26",
      "decision": "Dual HTTP + MCP per service",
      "rationale": "Dashboard calls HTTP, Agent SDK uses MCP native discovery. Both transports from day one.",
      "source": "user"
    },
    {
      "date": "2026-03-26",
      "decision": "Traefik-exposed services",
      "rationale": "Dashboard (Docker) needs direct access to tool services.",
      "source": "user"
    },
    {
      "date": "2026-03-26",
      "decision": "Slim daemon \u2014 keep Telegram + agent dispatch only",
      "rationale": "All tool logic moves to fleet. Daemon is just the message pump.",
      "source": "user"
    },
    {
      "date": "2026-03-26",
      "decision": "Include all dashboard work in v10",
      "rationale": "User wants auth + 5 polish specs alongside fleet build.",
      "source": "user"
    },
    {
      "date": "2026-03-26",
      "decision": "Migrate to shared homelab Postgres",
      "rationale": "Shared pgvector instance at port 5436 already hosts other project DBs. Consolidate.",
      "source": "user"
    },
