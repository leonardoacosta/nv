    {
      "date": "2026-03-26",
      "decision": "Clean-room TypeScript rewrite, not Rust port",
      "rationale": "Agent SDK + Vercel AI Gateway require TypeScript. OAuth tokens don't work with raw API.",
      "source": "user"
    },
    {
      "date": "2026-03-26",
      "decision": "Postgres + pgvector via local Docker, not SQLite",
      "rationale": "Vector search for memory, proper transactions, Drizzle ORM",
      "source": "user"
    },
    {
      "date": "2026-03-26",
      "decision": "CLI tool wrappers via Bash, not MCP servers",
      "rationale": "Simpler \u2014 Claude Code's Bash tool invokes CLIs directly. No MCP protocol overhead.",
      "source": "user"
    },
    {
      "date": "2026-03-26",
      "decision": "Bare metal systemd, not Docker for daemon",
      "rationale": "Agent SDK spawns Claude Code CLI subprocess \u2014 needs host access to ~/.claude/ credentials",
      "source": "system"
    },
    {
      "date": "2026-03-26",
      "decision": "Sequential /apply per spec (same as v7/v8)",
      "rationale": "Proven reliable. Most waves have file conflicts that force sequencing anyway.",
