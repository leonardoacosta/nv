[Unit]
Description=Nova Teams Webhook Relay
After=network-online.target nv.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 %h/nv/relays/teams/server.py
Restart=on-failure
RestartSec=10s
EnvironmentFile=-%h/.nv/env
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
